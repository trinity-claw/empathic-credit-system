# API
API_HOST=0.0.0.0
API_PORT=8000
API_USERNAME=admin
API_PASSWORD=changeme

# Models

MODEL_PATH=models/xgboost_financial.pkl

# Financial calibrator — use CALIBRATOR_PATH (legacy CALIBRATION_PATH / calibration_path
# are accepted by Settings but start.sh strips them when models/xgboost_financial_calibrator.pkl exists)
CALIBRATOR_PATH=models/xgboost_financial_calibrator.pkl
EMOTIONAL_MODEL_PATH=models/xgboost_emotional.pkl
EMOTIONAL_CALIBRATOR_PATH=models/xgboost_emotional_calibrator.pkl
MODEL_VERSION=v1.0.0

# Database
DATABASE_URL=sqlite:///./data/ecs.db

# Redis (async queue + pub/sub). Use localhost when API/worker run on the host (e.g. ./start.sh).
# docker-compose.yml overrides this to redis://redis:6379/0 for services on the Compose network.
REDIS_URL=redis://127.0.0.1:6379/0

# Logging
LOG_LEVEL=INFO

# Optional: if set, credit notifications are POSTed to this URL (e.g. FCM/APNS gateway or
# https://webhook.site/<uuid> for demos — see README "Testing the notification webhook").
# When unset, notifications are only logged as structured events (mock_mobile_push channel).
#NOTIFICATION_WEBHOOK_URL=
